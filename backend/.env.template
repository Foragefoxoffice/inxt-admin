PORT=5000
MONGO_URI=mongodb://localhost:27017/multi_country_cms
JWT_SECRET=your_jwt_secret_key_here
NODE_ENV=development

# AI Provider Switch: 'ollama' or 'openai'
AI_PROVIDER=ollama

